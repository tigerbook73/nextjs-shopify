# Shopify Storefront API 配置
# 复制此文件为 .env.local 并填入真实值

# 店铺域名（无 https://，无尾部斜杠）
# 示例：my-store.myshopify.com
SHOPIFY_STORE_DOMAIN=

# Storefront API Public Access Token
# 获取路径：Shopify Admin → Settings → Apps and sales channels → Develop apps
# 创建 App 后，在 API credentials 中启用 Storefront API 并生成 token
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Customer Account API Codegen
# Shopify Partners App → Authentication → API key
SHOPIFY_CUSTOMER_ACCOUNT_API_KEY=

# Customer Account OAuth
# Headless channel 的 client_id
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=
SHOPIFY_SHOP_ID=
NEXT_PUBLIC_APP_URL=
