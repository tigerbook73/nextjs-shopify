{
  "name": "nextjs-shopify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H nextjs-shopify.local --experimental-https --experimental-https-key ./.certs/nextjs-shopify.local-key.pem --experimental-https-cert ./.certs/nextjs-shopify.local.pem",
    "dev:http": "next dev -H nextjs-shopify.local",
    "build": "next build",
    "start": "next start",
    "format": "prettier --write .",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "codegen": "graphql-codegen",
    "env:check": "node scripts/check-env.mjs",
    "shopify:login": "shopify auth login",
    "shopify:logout": "shopify auth logout",
    "shopify:version": "shopify version",
    "prepare": "husky"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.1.0",
    "@playwright/test": "^1.60.0",
    "@shopify/api-codegen-preset": "^2.0.0",
    "@shopify/cli": "^3.94.3",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "graphql": "^16.14.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs}": [
      "prettier --write",
      "eslint --max-warnings 0 --no-warn-ignored"
    ],
    "*.{json,md,yml,css}": "prettier --write"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
